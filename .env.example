AZURE_DOCUMENT_INTELLIGENCE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
SMTP_HOST=
EMAIL_FROM=ap@example.com
# Any one of these Postgres URL names can be used. Vercel/Neon commonly provides DATABASE_URL or POSTGRES_URL.
DATABASE_URL=postgres://user:password@host:5432/invoice_management
# POSTGRES_URL=
BLOB_READ_WRITE_TOKEN=
# Optional. Use private only if the Vercel Blob store itself is configured for private access.
BLOB_ACCESS=public
